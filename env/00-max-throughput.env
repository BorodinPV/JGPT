# ============================================================
# JGPT Пресет 00 — Max throughput (первый в цепочке jgpt-smart.sh)
# Выше batch → больше токенов/шаг; при OOM smart понизит до 01-aggressive.
#
# Оценка (RTX-класс, seq=1024): batch=1, accum=6 → ~6k ток./шаг;
#   batch=4 → ~24k ток./шаг (часто упирается в VRAM).
#
# EARLY_STOP_OVERFIT=0: при sampled CE эвристика train↓/eval↑ даёт ложные остановы на batch=4.
# SAMPLED_CE_CANDIDATES=384: компромисс между 256 и 512, ближе train/eval.
# FP16_DYNAMIC_GROWTH_INTERVAL=60: чуть спокойнее scale после eval, как в stable.
# ============================================================

export JGPT_STATS_PRESET="00-max-throughput"
export JGPT_STATS_PRESET_IDX="0"

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=384

export JGPT_MAX_SEQ_LEN=1024
export JGPT_BATCH_SIZE=4

export JGPT_INTERACTIVE_EVERY=0

export JGPT_FP16_AUX_SOFTEN=1
export JGPT_FP16_AUX_SOFTEN_EVAL=2
export JGPT_FP16_DYNAMIC_INITIAL=32768
export JGPT_FP16_DYNAMIC_MAX=65536
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=60

export JGPT_EARLY_STOP_EVAL_PATIENCE=20
export JGPT_EARLY_STOP_OVERFIT=0

export JGPT_PRESET_NUM_LAYERS=12
# ↑ слои трансформера, не эпохи. Эпох по умолчанию 20 (smart50M); задать: JGPT_EPOCHS=N
export JGPT_FLASH_ATTENTION=1
export JGPT_FA_TILE_SIZE=144  # FlashAttention tile size (64-208, default 144)
export JGPT_DECODER_LAYER_CUDA_GRAPH=0
export JGPT_BATCH_PREFETCH=1

export JGPT_TRAIN_GPU_RESIDENT=1
export JGPT_DECODER_GPU_PIPELINE=1
export JGPT_DEVICE_LOGITS_TRAIN=1
export JGPT_DEVICE_DECODER_BWD=1
export JGPT_FULL_GPU_TRAIN=1
export JGPT_GPU_E2E_TRAIN=1
export JGPT_FP16_MATMUL=1
export JGPT_FUSED_FFN_RMS_W1W3=1
export JGPT_FUSED_LM_HEAD=1
export JGPT_ACTIVATION_CACHE_FP16=1
export JGPT_BATCH_PINNED=1
export JGPT_BLOCK_CACHE_POOL=1
export JGPT_BLOCK_CACHE_GROW_ONLY=1

export JGPT_DEBUG_GPU_TRAIN=0
export JGPT_TRAIN_PERF=1
export JGPT_TIMINGS=0
export JGPT_PROFILE=0
export JGPT_DECODER_LAYER_CUDA_GRAPH_LOG=0
export JGPT_TRAIN_VRAM_STEP_PROBE=0
export JGPT_BWD_LAYER_FINITE_CHECK=0
