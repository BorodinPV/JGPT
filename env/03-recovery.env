# ============================================================
# JGPT Пресет 03 — Recovery (аварийный)
# Последний рубеж: batch=1, очень осторожный FP16, seq=1024.
# seq НЕ меняем — иначе checkpoint несовместим с остальными пресетами.
# ============================================================

export JGPT_STATS_PRESET="03-recovery"
export JGPT_STATS_PRESET_IDX="3"

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=64

export JGPT_MAX_SEQ_LEN=1024                    # совпадает с 00/01/02 — checkpoint совместим

export JGPT_BATCH_SIZE=1                        # минимальный batch для экономии VRAM
export JGPT_INTERACTIVE_EVERY=0

export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=4096
export JGPT_FP16_DYNAMIC_MAX=16384
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=100

export JGPT_EARLY_STOP_EVAL_PATIENCE=50
export JGPT_EARLY_STOP_OVERFIT=0
