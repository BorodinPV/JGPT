# ============================================================
# JGPT Пресет 02 — Stable
# При частых FP16 overflow (scale скачет, шаги пропускаются)
# Меньше кандидатов → меньше нагрузка на GEMM → стабильнее
# ============================================================
export JGPT_STATS_PRESET="02-stable"
export JGPT_STATS_PRESET_IDX="2"
export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=256
export JGPT_MAX_SEQ_LEN=1024
export JGPT_INTERACTIVE_EVERY=500
export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=16384
export JGPT_FP16_DYNAMIC_MAX=65536
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=60
export JGPT_EARLY_STOP_EVAL_PATIENCE=30
export JGPT_EARLY_STOP_OVERFIT=0
export JGPT_PRESET_NUM_LAYERS=15
export JGPT_FLASH_ATTENTION=0
export JGPT_DECODER_LAYER_CUDA_GRAPH=0