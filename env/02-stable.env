# ============================================================
# JGPT Пресет 02 — Stable
# Мягче FP16 старт; FlashAttention вкл.; явный GPU-стек как у 01.
# Sampled CE: больше кандидатов — ближе градиент к full-vocab val (см. JGPT_SAMPLED_CE_CANDIDATES).
# Ранний останов по eval=0: при warmup 10% от всех шагов val долго плоский — не рубить обучение.
# При частых overflow: уменьшить JGPT_SAMPLED_CE_CANDIDATES (например 768 или 512).
# ============================================================

export JGPT_STATS_PRESET="02-stable"
export JGPT_STATS_PRESET_IDX="2"
export JGPT_EPOCHS=80
# Продолжать обучение на этом же пресете без авто-смены в smart-скрипте.
export JGPT_SMART_STICKY_PRESET=1

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=512

export JGPT_MAX_SEQ_LEN=1024
# Batch=2, accum=4 → эффективный batch=8192 (как 1×8), но ×2 throughput при свободной VRAM.
export JGPT_BATCH_SIZE=2
export JGPT_ACCUMULATION_STEPS=8

# Hold-out validation (AllBooksTrain): eval на отложенных окнах; seed — воспроизводимость split.
export JGPT_VAL_FRACTION=0.05
export JGPT_VAL_SEED=122

export JGPT_INTERACTIVE_EVERY=0

export JGPT_FP16_AUX_SOFTEN=1
export JGPT_FP16_AUX_SOFTEN_EVAL=2
export JGPT_FP16_DYNAMIC_INITIAL=65536
export JGPT_FP16_DYNAMIC_MAX=262144
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=100

# 0 = не останавливать из-за плато val (иначе при длинном cosine+warmup часто ложные срабатывания).
export JGPT_EARLY_STOP_EVAL_PATIENCE=0
export JGPT_EARLY_STOP_OVERFIT=0

export JGPT_PRESET_NUM_LAYERS=12
# ↑ слои трансформера, не эпохи. Эпох по умолчанию 20 (smart50M); задать: JGPT_EPOCHS=N
export JGPT_FLASH_ATTENTION=1
export JGPT_DECODER_LAYER_CUDA_GRAPH=0
export JGPT_BATCH_PREFETCH=1

# export JGPT_FINETUNE=1

export JGPT_TRAIN_GPU_RESIDENT=1
export JGPT_DECODER_GPU_PIPELINE=1
export JGPT_DEVICE_LOGITS_TRAIN=1
export JGPT_DEVICE_DECODER_BWD=1
export JGPT_FULL_GPU_TRAIN=1
export JGPT_GPU_E2E_TRAIN=1
export JGPT_FP16_MATMUL=1
export JGPT_FUSED_FFN_RMS_W1W3=1
export JGPT_FUSED_LM_HEAD=1
export JGPT_ACTIVATION_CACHE_FP16=1
export JGPT_BATCH_PINNED=1
export JGPT_BLOCK_CACHE_POOL=0
export JGPT_BLOCK_CACHE_GROW_ONLY=1

export JGPT_DEBUG_GPU_TRAIN=0
export JGPT_TRAIN_PERF=1
export JGPT_TIMINGS=0
export JGPT_PROFILE=0
export JGPT_DECODER_LAYER_CUDA_GRAPH_LOG=0
export JGPT_TRAIN_VRAM_STEP_PROBE=0
export JGPT_BWD_LAYER_FINITE_CHECK=0

# Опционально при плато: снизить базовый LR без правки пресета (см. LLMConfig.applyLearningRateOverrideFromEnv).
export JGPT_LEARNING_RATE=1e-4
