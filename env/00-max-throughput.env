# ============================================================
# JGPT Пресет 00 — Max Throughput (экспериментальный)
# Пробует batch=4 для ~18k токенов/с
# ВНИМАНИЕ: может дать OOM — smart-wrapper автоматически
# понизит до 01-aggressive если упадёт с cudaMalloc
#
# Математика (RTX 3080):
#   batch=1, seq=1024, accum=6 → 6144 т/шаг → ~7k т/с
#   batch=4, seq=1024, accum=6 → 24576 т/шаг → ~16-18k т/с (оценка)
#   30k+ т/с → нужен Flash Attention (изменение кода)
# ============================================================

export JGPT_STATS_PRESET="00-max-throughput"
export JGPT_STATS_PRESET_IDX="0"

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=512

export JGPT_MAX_SEQ_LEN=1024
export JGPT_BATCH_SIZE=2             # ~2.5x токенов/с есмсчмчссмчмчсмчсм

export JGPT_INTERACTIVE_EVERY=0      # выключить при большом batch (нагрузка)

export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=65536
export JGPT_FP16_DYNAMIC_MAX=65536
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=50

export JGPT_EARLY_STOP_EVAL_PATIENCE=20
export JGPT_EARLY_STOP_OVERFIT=0
