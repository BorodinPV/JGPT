# ============================================================
# JGPT Пресет 02 — Stable
# Мягче FP16 старт; FlashAttention вкл.; явный GPU-стек как у 01.
# Sampled CE: больше кандидатов — ближе градиент к full-vocab val (см. JGPT_SAMPLED_CE_CANDIDATES).
# Ранний останов по eval=0: при warmup 10% от всех шагов val долго плоский — не рубить обучение.
# При частых overflow: уменьшить JGPT_SAMPLED_CE_CANDIDATES (например 768 или 512).
#
# FlashAttention tile size (compile-time): задать JGPT_FA_TILE_SIZE=N при cmake
# Допустимые: 64, 96, 128, 144, 160, 192, 208. Больше = быстрее, но больше VRAM.
# Пример: JGPT_FA_TILE_SIZE=128 cmake --build build
# ============================================================

# Имя пресета и его индекс для статистики
export JGPT_STATS_PRESET="02-stable"
export JGPT_STATS_PRESET_IDX="2"

# Количество эпох обучения
export JGPT_EPOCHS=80

# Продолжать обучение на этом же пресете без авто-смены в smart-скрипте
export JGPT_SMART_STICKY_PRESET=1

# Режим вычисления loss: full = полный vocab, sampled = выборка кандидатов
export JGPT_TRAIN_LOSS_MODE=full

# Асинхронное вычисление cross-entropy (0 = синхронно, надежнее)
export JGPT_CE_ASYNC=0

# Количество кандидатов для sampled CE (больше = точнее, но медленнее)
export JGPT_SAMPLED_CE_CANDIDATES=8000

# Максимальная длина последовательности в токенах
export JGPT_MAX_SEQ_LEN=1024

# Размер батча и шаги аккумуляции градиентов
# Batch=2, accum=16 → эффективный batch=32768 токенов
export JGPT_BATCH_SIZE=2
export JGPT_ACCUMULATION_STEPS=32

# Размер тайла FlashAttention (64-208). Больше = быстрее, но больше VRAM
export JGPT_FA_TILE_SIZE=128

# Hold-out validation: доля данных для валидации и seed для воспроизводимости
export JGPT_VAL_FRACTION=0.05
export JGPT_VAL_SEED=123

# Интерактивная генерация текста каждые N шагов (0 = отключено)
export JGPT_INTERACTIVE_EVERY=0

# Смягчение FP16 после вспомогательных операций (инференс, eval)
export JGPT_FP16_AUX_SOFTEN=1
export JGPT_FP16_AUX_SOFTEN_EVAL=2

# Начальный и максимальный loss scale для динамического FP16
export JGPT_FP16_DYNAMIC_INITIAL=65536
export JGPT_FP16_DYNAMIC_MAX=262144

# Интервал роста loss scale (в шагах)
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=50

# Терпение раннего останова по eval (0 = не останавливать)
export JGPT_EARLY_STOP_EVAL_PATIENCE=0

# Останавливать при переобучении (0 = не останавливать)
export JGPT_EARLY_STOP_OVERFIT=0

# Количество слоев трансформера
export JGPT_PRESET_NUM_LAYERS=20

# Включить FlashAttention (1 = да, быстрее и меньше VRAM)
export JGPT_FLASH_ATTENTION=1

# CUDA Graph для слоев декодера (0 = отключено, надежнее)
export JGPT_DECODER_LAYER_CUDA_GRAPH=0

# Предзагрузка следующего батча (1 = включено, быстрее)
export JGPT_BATCH_PREFETCH=1

# Режим дообучения (раскомментировать для finetune)
# export JGPT_FINETUNE=1

# Периодический trim CUDA memory pool каждые N шагов (0 = отключить)
export JGPT_CUDA_TRIM_EVERY_STEPS=100

# GPU-резидентный режим обучения (все тензоры на GPU)
export JGPT_TRAIN_GPU_RESIDENT=1

# GPU pipeline для декодера
export JGPT_DECODER_GPU_PIPELINE=1

# Вычисление логитов на GPU при обучении
export JGPT_DEVICE_LOGITS_TRAIN=1

# Обратное распространение на GPU в декодере
export JGPT_DEVICE_DECODER_BWD=1

# Полное GPU-обучение (все операции на GPU)
export JGPT_FULL_GPU_TRAIN=1

# End-to-end GPU обучение
export JGPT_GPU_E2E_TRAIN=1

# FP16 матричное умножение (быстрее, меньше памяти)
export JGPT_FP16_MATMUL=1

# Fused FFN + RMSNorm + W1W3 (оптимизированное ядро)
export JGPT_FUSED_FFN_RMS_W1W3=1

# Fused LM head (оптимизированное ядро)
export JGPT_FUSED_LM_HEAD=1

# FP16 кэш активаций (экономит 50% VRAM на активациях)
export JGPT_ACTIVATION_CACHE_FP16=1

# Pinned memory для батчей (быстрее H2D копирование)
export JGPT_BATCH_PINNED=1

# Пул для переиспользования кэшей блоков (1 = включено)
export JGPT_BLOCK_CACHE_POOL=1

# Режим только роста кэшей (0 = отключено, безопаснее для памяти)
export JGPT_BLOCK_CACHE_GROW_ONLY=0

# Максимальный размер пула кэшей блоков (меньше = меньше VRAM, 1 = минимум)
export JGPT_BLOCK_CACHE_POOL_MAX=2

# Интервал очистки ThreadLocal пула (количество обращений). Меньше = чаще очистка, меньше утечка VRAM
export JGPT_BLOCK_CACHE_POOL_CLEANUP_INTERVAL=100

# Отладка GPU обучения (0 = отключено)
export JGPT_DEBUG_GPU_TRAIN=0

# Сбор статистики производительности (1 = включено)
export JGPT_TRAIN_PERF=1

# Замеры времени операций (0 = отключено)
export JGPT_TIMINGS=0

# Профилирование (0 = отключено)
export JGPT_PROFILE=0

# Логирование CUDA Graph декодера (0 = отключено)
export JGPT_DECODER_LAYER_CUDA_GRAPH_LOG=0

# Проба VRAM на каждом шаге (0 = отключено, медленнее)
export JGPT_TRAIN_VRAM_STEP_PROBE=0

# Проверка конечности градиентов в backward (0 = отключено)
export JGPT_BWD_LAYER_FINITE_CHECK=0

# Опционально при плато: снизить базовый LR без правки пресета
#export JGPT_LEARNING_RATE=3e-4

# Периодическая очистка VRAM каждые N шагов для предотвращения утечки памяти.
# Очищает активационные кэши модели и ThreadLocal пулы.
# Меньше значение = чаще очистка, меньше утечка, но немного медленнее.
# 0 = отключить периодическую очистку (только в конце эпохи)
export JGPT_VRAM_CLEANUP_EVERY_STEPS=20
