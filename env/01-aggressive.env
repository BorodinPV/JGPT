# ============================================================
# JGPT Пресет 01 — Aggressive (проверено рабочим)
# ~7000 токенов/с, RTX 3080, seq=1024, batch=1
# FP16 scale колеблется 32768↔65536 (восстанавливается за 50 шагов)
# ============================================================

export JGPT_STATS_PRESET="01-aggressive"
export JGPT_STATS_PRESET_IDX="1"

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=512

export JGPT_MAX_SEQ_LEN=1024
# JGPT_BATCH_SIZE не задан — дефолт=1

export JGPT_INTERACTIVE_EVERY=500
# export JGPT_SAMPLE_PROMPT="он вышел из дома ранним утром|она взяла книгу со стола"

export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=65536
export JGPT_FP16_DYNAMIC_MAX=65536
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=50   # < 100 (eval_every) — критично!

export JGPT_EARLY_STOP_EVAL_PATIENCE=20
export JGPT_EARLY_STOP_OVERFIT=0
