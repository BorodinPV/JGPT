# ============================================================
# JGPT Пресет 03 — Recovery (аварийный)
# При OOM (cudaMalloc failed) — урезаем seq вдвое
# Качество пострадает, но обучение продолжится
# ============================================================

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=128

export JGPT_MAX_SEQ_LEN=512                     # вдвое меньше VRAM на attention

export JGPT_INTERACTIVE_EVERY=0                 # генерацию выключаем

export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=8192
export JGPT_FP16_DYNAMIC_MAX=32768
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=80

export JGPT_EARLY_STOP_EVAL_PATIENCE=50
export JGPT_EARLY_STOP_OVERFIT=0
