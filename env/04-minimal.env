# ============================================================
# JGPT Пресет 04 — Minimal (ещё ниже recovery)
# batch=1 как в 03; меньше sampled CE; FP16 ещё осторожнее; seq=1024 без изменений.
# ============================================================

export JGPT_STATS_PRESET="04-minimal"
export JGPT_STATS_PRESET_IDX="4"

export JGPT_TRAIN_LOSS_MODE=sampled
export JGPT_CE_ASYNC=0
export JGPT_SAMPLED_CE_CANDIDATES=32

export JGPT_MAX_SEQ_LEN=1024

export JGPT_BATCH_SIZE=1
export JGPT_INTERACTIVE_EVERY=0

export JGPT_FP16_AUX_SOFTEN=0
export JGPT_FP16_DYNAMIC_INITIAL=2048
export JGPT_FP16_DYNAMIC_MAX=8192
export JGPT_FP16_DYNAMIC_GROWTH_INTERVAL=120

export JGPT_EARLY_STOP_EVAL_PATIENCE=80
export JGPT_EARLY_STOP_OVERFIT=0
